{
  "name": "cron-run",
  "version": "1.0.0",
  "runtime": "node",
  "entrypoint": "index.ts",
  "description": "Trigger a cron job to run immediately, bypassing its schedule",
  "parameters": {
    "type": "object",
    "required": ["jobId"],
    "properties": {
      "jobId": {
        "type": "string",
        "description": "ID of the job to run"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "Whether the job was successfully triggered"
      },
      "runId": {
        "type": "string",
        "description": "ID of the triggered run"
      }
    }
  }
}
