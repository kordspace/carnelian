    {
      "key": "PERPLEXITY_API_KEY",
      "label": "Perplexity API Key",
      "secret": true
    },
    {
      "key": "OPENROUTER_API_KEY",
      "label": "OpenRouter API Key",
      "secret": true
    }
  ]
}
