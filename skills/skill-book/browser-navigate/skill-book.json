{
  "name": "browser-navigate",
  "version": "1.0.0",
  "runtime": "node",
  "entrypoint": "index.ts",
  "description": "Navigate browser to a URL with configurable wait conditions",
  "parameters": {
    "type": "object",
    "required": ["url"],
    "properties": {
      "url": {
        "type": "string",
        "description": "URL to navigate to"
      },
      "profile": {
        "type": "string",
        "description": "Browser profile to use"
      },
      "waitUntil": {
        "type": "string",
        "enum": ["load", "domcontentloaded", "networkidle"],
        "default": "load",
        "description": "Wait condition before considering navigation complete"
      },
      "timeout": {
        "type": "number",
        "default": 30000,
        "description": "Navigation timeout in milliseconds"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string",
        "description": "Final URL after navigation"
      },
      "title": {
        "type": "string",
        "description": "Page title"
      }
    }
  }
}
