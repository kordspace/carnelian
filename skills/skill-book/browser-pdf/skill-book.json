{
  "name": "browser-pdf",
  "version": "1.0.0",
  "runtime": "node",
  "entrypoint": "index.ts",
  "description": "Generate a PDF from the current browser page",
  "parameters": {
    "type": "object",
    "properties": {
      "profile": {
        "type": "string",
        "description": "Browser profile to use"
      },
      "format": {
        "type": "string",
        "enum": ["A4", "Letter", "Legal"],
        "default": "A4",
        "description": "Paper format"
      },
      "landscape": {
        "type": "boolean",
        "default": false,
        "description": "Use landscape orientation"
      },
      "printBackground": {
        "type": "boolean",
        "default": true,
        "description": "Include background graphics"
      },
      "scale": {
        "type": "number",
        "default": 1,
        "minimum": 0.1,
        "maximum": 2,
        "description": "Scale of the webpage rendering (0.1-2)"
      },
      "margin": {
        "type": "object",
        "properties": {
          "top": {
            "type": "string",
            "description": "Top margin (e.g., '1cm', '10mm')"
          },
          "right": {
            "type": "string",
            "description": "Right margin"
          },
          "bottom": {
            "type": "string",
            "description": "Bottom margin"
          },
          "left": {
            "type": "string",
            "description": "Left margin"
          }
        },
        "description": "Page margins"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "pdf": {
        "type": "string",
        "description": "Base64 encoded PDF data"
      },
      "size": {
        "type": "number",
        "description": "PDF size in bytes"
      }
    }
  }
}
