{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                grant_id,\n                subject_type,\n                subject_id,\n                capability_key,\n                scope,\n                constraints,\n                approved_by,\n                created_at,\n                expires_at\n            FROM capability_grants\n            WHERE subject_type = $1 AND subject_id = $2\n              AND (expires_at IS NULL OR expires_at > NOW())\n            ORDER BY created_at DESC\n            ",
