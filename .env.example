# =============================================================================
# Carnelian OS - Environment Variables
# =============================================================================
# Copy this file to .env and customize for your environment.
# Do NOT commit .env to version control (contains secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
# Database credentials and connection settings for PostgreSQL with pgvector.

# PostgreSQL user (default: carnelian)
POSTGRES_USER=carnelian

# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=carnelian

# PostgreSQL database name
POSTGRES_DB=carnelian

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# pgvector embedding dimensions (OpenAI ada-002 uses 1536)
PGVECTOR_DIMS=1536

# Full database connection URL for Rust crates (SQLx)
# Local development: postgresql://carnelian:carnelian@localhost:5432/carnelian
# Docker internal:   postgresql://carnelian:carnelian@carnelian-postgres:5432/carnelian
DATABASE_URL=postgresql://carnelian:carnelian@localhost:5432/carnelian

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
# Local LLM inference settings for Ollama runtime.

# Ollama API port (default: 11434)
OLLAMA_PORT=11434

# Ollama host binding (0.0.0.0 for Docker, 127.0.0.1 for local-only)
OLLAMA_HOST=0.0.0.0:11434

# Ollama models directory (inside container)
OLLAMA_MODELS=/root/.ollama

# Default model to use for inference
# Machine Profile Recommendations:
# - Thummim (RTX 2080 Super, 8GB VRAM, 32GB RAM): deepseek-r1:7b
# - Urim (RTX 2080 Ti, 11GB VRAM, 64GB RAM): deepseek-r1:32b or deepseek-r1:7b
OLLAMA_MODEL=deepseek-r1:7b

# Keep models loaded in memory (-1 = indefinitely, 0 = unload immediately)
OLLAMA_KEEP_ALIVE=-1

# Number of GPU layers to use (999 = all available)
OLLAMA_NUM_GPU=999

# -----------------------------------------------------------------------------
# Machine Profile
# -----------------------------------------------------------------------------
# Select your machine profile for optimized resource allocation.
# Options: thummim, urim

# Thummim: RTX 2080 Super (8GB VRAM), 32GB RAM - constrained profile
# Urim: RTX 2080 Ti (11GB VRAM), 64GB RAM - high-end profile
MACHINE_PROFILE=thummim

# -----------------------------------------------------------------------------
# Carnelian Core Configuration
# -----------------------------------------------------------------------------
# Settings for the Rust core orchestrator.

# HTTP API port for core orchestrator (default: 18789)
CARNELIAN_HTTP_PORT=18789

# WebSocket port for event streaming (default: 18790)
CARNELIAN_WS_PORT=18790

# Ollama API endpoint (use Docker internal URL when running in container)
# Local: http://localhost:11434
# Docker: http://carnelian-ollama:11434
CARNELIAN_OLLAMA_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: ERROR, WARN, INFO, DEBUG, TRACE

LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Owner Keypair Configuration
# -----------------------------------------------------------------------------
# Path to Ed25519 keypair file for owner-signed authority.
# The keypair is used to sign capability grants and verify owner identity.
#
# To generate a new keypair:
#   openssl genpkey -algorithm ed25519 -out ~/.carnelian/owner.key
#   chmod 600 ~/.carnelian/owner.key

# CARNELIAN_OWNER_KEYPAIR_PATH=~/.carnelian/owner.key
