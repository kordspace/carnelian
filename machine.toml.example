# 🔥 Carnelian OS Machine Configuration
#
# Copy this file to `machine.toml` and customize for your environment.
#
# Configuration Loading Order:
# 1. Default values (built into the application)
# 2. machine.toml (this file)
# 3. Environment variables (highest precedence)
#
# Security Notes:
# - Sensitive values (DATABASE_URL, keypair) should use environment variables
# - Never commit machine.toml with secrets to version control
# - Owner keypair files should have permissions 0600 (read/write owner only)

# =============================================================================
# Machine Profile
# =============================================================================
# Determines resource limits and default model settings.
#
# Available profiles:
# - "standard": Entry-level (8GB VRAM, 32GB RAM) - good for most tasks
# - "performance": High-end (11GB+ VRAM, 64GB RAM) - for demanding workloads
# - "custom": User-defined settings (see [machine] section below)
#
# Can be overridden with MACHINE_PROFILE environment variable.

machine_profile = "standard"

# =============================================================================
# Agent Identity
# =============================================================================
# Customize the AI assistant's display name. This name appears in UI, logs,
# and channel adapter responses (Discord, Telegram, etc.)
#
# Can be overridden with CARNELIAN_AGENT_NAME environment variable.

agent_name = "Lian"

# =============================================================================
# Server Configuration
# =============================================================================
# HTTP port for the API server (serves both REST and WebSocket).
#
# Port 18789: Core HTTP API + WebSocket endpoint (ws://host:18789/v1/events/ws)
# Port 18790: Reserved for future LLM Gateway Service
#
# Can be overridden with PORT or CARNELIAN_HTTP_PORT environment variable.

http_port = 18789

# =============================================================================
# Skill Execution Configuration
# =============================================================================
# Timeouts and output limits for worker skill invocations.

# Skill execution timeout in seconds (default: 300 = 5 minutes)
skill_timeout_secs = 300

# Grace period after SIGTERM before SIGKILL in seconds (default: 5)
skill_timeout_grace_period_secs = 5

# Maximum skill output size in bytes (default: 1048576 = 1MB)
skill_max_output_bytes = 1048576

# Maximum number of log lines per skill execution (default: 10000)
skill_max_log_lines = 10000

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection settings.
#
# RECOMMENDED: Use DATABASE_URL environment variable instead of this file
# for production deployments to avoid committing credentials.

database_url = "postgresql://carnelian:carnelian@localhost:5432/carnelian"

# Connection pool settings
db_max_connections = 10
db_connection_timeout_secs = 30
db_idle_timeout_secs = 600

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: ERROR, WARN, INFO, DEBUG, TRACE
#
# Can be overridden with LOG_LEVEL or RUST_LOG environment variable.

log_level = "INFO"

# =============================================================================
# Ollama Configuration
# =============================================================================
# Local LLM inference via Ollama.
#
# Can be overridden with CARNELIAN_OLLAMA_URL environment variable.

ollama_url = "http://localhost:11434"

# =============================================================================
# Owner Keypair Configuration
# =============================================================================
# Ed25519 keypair for owner-signed authority.
#
# The keypair is used to sign capability grants and verify owner identity.
# If not configured, features requiring signed authority will be unavailable.
#
# Can be overridden with CARNELIAN_OWNER_KEYPAIR_PATH environment variable.
#
# Supported key formats:
# 1. PEM/PKCS8 (recommended) - Generated by OpenSSL:
#      openssl genpkey -algorithm ed25519 -out ~/.carnelian/owner.key
#      chmod 600 ~/.carnelian/owner.key
#
# 2. Raw 32-byte seed - Direct binary file:
#      head -c 32 /dev/urandom > ~/.carnelian/owner.key
#      chmod 600 ~/.carnelian/owner.key
#
# Fallback: If no file is configured, the system will check the database
# `config_store` table for key `owner_keypair`. For encrypted storage,
# set CARNELIAN_KEYPAIR_PASSPHRASE environment variable.

# owner_keypair_path = "~/.carnelian/owner.key"

# =============================================================================
# Custom Machine Configuration
# =============================================================================
# Only used when machine_profile = "custom".
# Allows fine-grained control over resource limits.

# [custom_machine_config]
# max_workers = 4
# max_memory_mb = 16384
# gpu_enabled = true
# default_model = "deepseek-r1:7b"

# =============================================================================
# Workspace Scanning Configuration
# =============================================================================
# Automatic task discovery from TASK: and TODO: markers in source files.
#
# During each heartbeat, Carnelian scans configured workspace paths for
# markers and auto-queues safe tasks to the task queue. Privileged tasks
# (containing keywords like "delete", "deploy", "production") are skipped.

# Maximum tasks to auto-queue per heartbeat (default: 5)
# Set to 0 to disable workspace scanning entirely.
max_tasks_per_heartbeat = 5

# Workspace paths to scan for markers (default: ["."])
# Paths are relative to the working directory where Carnelian is started.
# Multiple paths can be specified as an array.
workspace_scan_paths = ["."]

# Example: Scan multiple project directories
# workspace_scan_paths = ["./projects/app1", "./projects/app2", "./docs"]

# Scannable file extensions (hardcoded):
# rs, py, ts, js, tsx, jsx, go, java, c, cpp, h, hpp, rb, sh, bash, zsh,
# toml, yaml, yml, json, md, txt
#
# Excluded directories (hardcoded):
# target, node_modules, .git, __pycache__, dist, build, vendor, .* (hidden)
#
# Privileged keywords (tasks containing these are NOT auto-queued):
# delete, drop, migrate, deploy, production, credential, secret, key rotation,
# sudo, admin, root, destroy, truncate, revert, rollback, security, permission,
# privilege
