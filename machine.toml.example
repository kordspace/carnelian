# 🔥 Carnelian OS Machine Configuration
#
# Copy this file to `machine.toml` and customize for your environment.
#
# Configuration Loading Order:
# 1. Default values (built into the application)
# 2. machine.toml (this file)
# 3. Environment variables (highest precedence)
#
# Security Notes:
# - Sensitive values (DATABASE_URL, keypair) should use environment variables
# - Never commit machine.toml with secrets to version control
# - Owner keypair files should have permissions 0600 (read/write owner only)

# =============================================================================
# Machine Profile
# =============================================================================
# Determines resource limits and default model settings.
#
# Available profiles:
# - "thummim": RTX 2080 Super (8GB VRAM), 32GB RAM - constrained profile
# - "urim": RTX 2080 Ti (11GB VRAM), 64GB RAM - high-end profile
# - "custom": User-defined settings (see [machine] section below)
#
# Can be overridden with MACHINE_PROFILE environment variable.

machine_profile = "thummim"

# =============================================================================
# Server Configuration
# =============================================================================
# HTTP and WebSocket ports for the API server.
#
# Can be overridden with:
# - PORT or CARNELIAN_HTTP_PORT for http_port
# - CARNELIAN_WS_PORT for ws_port

http_port = 18789
ws_port = 18790

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection settings.
#
# RECOMMENDED: Use DATABASE_URL environment variable instead of this file
# for production deployments to avoid committing credentials.

database_url = "postgresql://carnelian:carnelian@localhost:5432/carnelian"

# Connection pool settings
db_max_connections = 10
db_connection_timeout_secs = 30
db_idle_timeout_secs = 600

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: ERROR, WARN, INFO, DEBUG, TRACE
#
# Can be overridden with LOG_LEVEL or RUST_LOG environment variable.

log_level = "INFO"

# =============================================================================
# Ollama Configuration
# =============================================================================
# Local LLM inference via Ollama.
#
# Can be overridden with CARNELIAN_OLLAMA_URL environment variable.

ollama_url = "http://localhost:11434"

# =============================================================================
# Owner Keypair Configuration
# =============================================================================
# Ed25519 keypair for owner-signed authority.
#
# The keypair is used to sign capability grants and verify owner identity.
# If not configured, features requiring signed authority will be unavailable.
#
# Can be overridden with CARNELIAN_OWNER_KEYPAIR_PATH environment variable.
#
# Supported key formats:
# 1. PEM/PKCS8 (recommended) - Generated by OpenSSL:
#      openssl genpkey -algorithm ed25519 -out ~/.carnelian/owner.key
#      chmod 600 ~/.carnelian/owner.key
#
# 2. Raw 32-byte seed - Direct binary file:
#      head -c 32 /dev/urandom > ~/.carnelian/owner.key
#      chmod 600 ~/.carnelian/owner.key
#
# Fallback: If no file is configured, the system will check the database
# `config_store` table for key `owner_keypair`. For encrypted storage,
# set CARNELIAN_KEYPAIR_PASSPHRASE environment variable.

# owner_keypair_path = "~/.carnelian/owner.key"

# =============================================================================
# Custom Machine Configuration
# =============================================================================
# Only used when machine_profile = "custom".
# Allows fine-grained control over resource limits.

# [custom_machine_config]
# max_workers = 4
# max_memory_mb = 16384
# gpu_enabled = true
# default_model = "deepseek-r1:7b"
